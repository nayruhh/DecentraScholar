# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# Pinata JWT for IPFS pinning. Leave blank to use local file storage instead.
PINATA_JWT=

# Turso cloud SQLite (optional — falls back to local file:data/reader-interactions.db)
# Create a database at https://turso.tech, then run:
#   turso db show <db-name>   → copy the URL (libsql://...)
#   turso db tokens create <db-name>  → copy the auth token
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
